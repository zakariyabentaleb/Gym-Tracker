{
  "info": {
    "_postman_id": "b7d9a1d8-0000-4000-8000-000000000002",
    "name": "GymTracker - Courses & Bookings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection to test Courses, CourseSchedules and Bookings API for GymTracker."
  },
  "item": [
    {
      "name": "Auth - Admin Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminPassword\"\n}" },
        "url": { "raw": "{{base_url}}/api/auth/login" }
      },
      "event": [
        { "listen": "test", "script": { "exec": [
          "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
          "var json = pm.response.json();",
          "if (json && json.token) { pm.environment.set('admin_token', json.token); pm.environment.set('token_type', (json.tokenType||'Bearer')); }",
          "pm.test(\"admin_token saved\", function () { pm.expect(pm.environment.get('admin_token')).to.be.a('string'); });"
        ] } }
      ]
    },
    {
      "name": "Auth - Member Login",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"member1\",\n  \"password\": \"secret123\"\n}" },
        "url": { "raw": "{{base_url}}/api/auth/login" }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
        "var json = pm.response.json();",
        "if (json && json.token) { pm.environment.set('member_token', json.token); pm.environment.set('token_type', (json.tokenType||'Bearer')); }",
        "pm.test(\"member_token saved\", function () { pm.expect(pm.environment.get('member_token')).to.be.a('string'); });"
      ] } } ]
    },
    {
      "name": "Courses - Create Course (admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{admin_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Yoga\",\n  \"description\": \"Relaxing yoga class\",\n  \"durationMinutes\": 60,\n  \"capacity\": 10\n}" },
        "url": { "raw": "{{base_url}}/api/courses" }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "pm.test(\"Status is 200 or 201\", function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
        "var json = pm.response.json(); if (json && json.id) pm.environment.set('course_id', json.id);",
        "pm.test(\"course_id saved\", function () { pm.expect(pm.environment.get('course_id')).to.be.a('string'); });"
      ] } } ]
    },
    {
      "name": "CourseSchedules - Create Schedule (admin)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"courseId\": {{course_id}},\n  \"coachId\": null,\n  \"room\": \"Room A\",\n  \"startTime\": \"2026-02-20T10:00:00\",\n  \"endTime\": \"2026-02-20T11:00:00\",\n  \"capacity\": 8\n}" },
        "url": { "raw": "{{base_url}}/api/course-schedules" }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "pm.test(\"Status is 200 or 201\", function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
        "var json = pm.response.json(); if (json && json.id) pm.environment.set('schedule_id', json.id);",
        "pm.test(\"schedule_id saved\", function () { pm.expect(pm.environment.get('schedule_id')).to.be.a('string'); });"
      ] } } ]
    },
    {
      "name": "Bookings - Create Booking (admin)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"scheduleId\": {{schedule_id}},\n  \"memberId\": {{member_id}}\n}" },
        "url": { "raw": "{{base_url}}/api/bookings" }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "pm.test(\"Status is 200 or 201\", function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
        "var json = pm.response.json(); if (json && json.id) pm.environment.set('booking_id', json.id);",
        "pm.test(\"booking_id saved\", function () { pm.expect(pm.environment.get('booking_id')).to.be.a('string'); });"
      ] } } ]
    },
    {
      "name": "Bookings - Create Booking (me) (member)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{member_token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"scheduleId\": {{schedule_id}}\n}" },
        "url": { "raw": "{{base_url}}/api/bookings/me" }
      }
    },
    {
      "name": "Bookings - List by Schedule (admin)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": { "raw": "{{base_url}}/api/bookings/schedule/{{schedule_id}}" }
      }
    },
    {
      "name": "Bookings - My Bookings (member)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{member_token}}" } ],
        "url": { "raw": "{{base_url}}/api/bookings/me" }
      }
    },
    {
      "name": "Bookings - Cancel Booking (member/admin)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Authorization", "value": "Bearer {{admin_token}}" } ],
        "url": { "raw": "{{base_url}}/api/bookings/{{booking_id}}/cancel" }
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "admin_token", "value": "" },
    { "key": "member_token", "value": "" },
    { "key": "course_id", "value": "" },
    { "key": "schedule_id", "value": "" },
    { "key": "booking_id", "value": "" },
    { "key": "member_id", "value": "7" }
  ]
}

