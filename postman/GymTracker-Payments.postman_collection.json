{
  "info": {
    "_postman_id": "b7d9a1d8-0000-4000-8000-000000000001",
    "name": "GymTracker - Payments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection to test Payments API for GymTracker (includes auth requests to get tokens)."
  },
  "item": [
    {
      "name": "Auth - Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminPassword\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "if (json && json.token) { pm.environment.set(\"admin_token\", json.token); pm.environment.set(\"token_type\", (json.tokenType||'Bearer')); }",
              "pm.test(\"admin_token saved\", function () { pm.expect(pm.environment.get(\"admin_token\")).to.be.a(\"string\"); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Member Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"member1\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "if (json && json.token) { pm.environment.set(\"member_token\", json.token); pm.environment.set(\"token_type\", (json.tokenType||'Bearer')); }",
              "pm.test(\"member_token saved\", function () { pm.expect(pm.environment.get(\"member_token\")).to.be.a(\"string\"); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Payments - Create Payment (admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"subscriptionId\": {{subscription_id}},\n  \"memberId\": {{member_id}},\n  \"amountCents\": 250000,\n  \"method\": \"CARD\",\n  \"reference\": \"POS-{{$timestamp}}-01\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/payments"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 or 200\", function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
              "var json = pm.response.json();",
              "if (json && json.id) { pm.environment.set(\"payment_id\", json.id); }",
              "pm.test(\"payment_id saved\", function () { pm.expect(pm.environment.get(\"payment_id\")).to.be.a(\"string\"); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Payments - Get Payment by Id (admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/{{payment_id}}"
        }
      }
    },
    {
      "name": "Payments - List by Member (admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/member/{{member_id}}"
        }
      }
    },
    {
      "name": "Payments - List by Subscription (admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/subscription/{{subscription_id}}"
        }
      }
    },
    {
      "name": "Payments - My Payments (member)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{member_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/payments/me"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "admin_token",
      "value": ""
    },
    {
      "key": "member_token",
      "value": ""
    },
    {
      "key": "member_id",
      "value": "7"
    },
    {
      "key": "subscription_id",
      "value": "12"
    },
    {
      "key": "payment_id",
      "value": ""
    }
  ]
}

